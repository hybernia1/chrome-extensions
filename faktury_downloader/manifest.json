{
  "manifest_version": 3,
  "name": "Alza Faktury Sidebar",
  "version": "1.2",
  "permissions": [
    "tabs",
    "scripting",
    "downloads",
    "storage"
  ],
  "host_permissions": [
    "https://www.alza.cz/*",
    "https://pdf.alza.cz/*",
    "https://webapi.alza.cz/*",
    "http://10.3.109.33/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.alza.cz/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "page_bridge.js"
      ],
      "matches": [
        "https://www.alza.cz/*"
      ]
    }
  ]
}
